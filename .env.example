# Copy this file to .env and fill in your real keys.
# .env is in .gitignore — never commit real keys.

# Alibaba DashScope (Tongyi Qianwen / Qwen-Image / Wan)
# Get one at: https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=

# Kling AI (Kuaishou) — image-to-video
# Get one at: https://klingai.kuaishou.com/dev
KLING_API_KEY=
KLING_API_SECRET=

# MiniMax (Xiyu Technology) — image generation (image-01)
# Already configured in your shell? Just leave blank.
# Otherwise get one at: https://platform.minimaxi.com/user-center/basic-information/interface-key
MINIMAX_API_KEY=
